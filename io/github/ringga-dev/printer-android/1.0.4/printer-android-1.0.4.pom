  <modelVersion>4.0.0</modelVersion>
  <groupId>io.github.ringga-dev</groupId>
  <artifactId>printer-android</artifactId>
  <version>1.0.4</version>
  <packaging>aar</packaging>
  <name>KmpPrinter</name>
  <description>KmpPrinter: Professional Kotlin Multiplatform Thermal Printing Library for ESC/POS.</description>
  <url>https://github.com/ringga-dev/Printer-ESC-POS</url>
  <licenses>
    <license>
      <name>MIT License</name>
      <url>https://opensource.org/licenses/MIT</url>
    </license>
  </licenses>
  <developers>
    <developer>
      <id>ringga</id>
      <name>Ringga</name>
      <email>ringga@dev.com</email>
    </developer>
  </developers>
  <scm>
    <connection>scm:git:git://github.com/ringga-dev/Printer-ESC-POS.git</connection>
    <developerConnection>scm:git:ssh://github.com/ringga-dev/Printer-ESC-POS.git</developerConnection>
    <url>https://github.com/ringga-dev/Printer-ESC-POS</url>
  </scm>
